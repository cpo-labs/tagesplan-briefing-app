# Copy to .env.local and fill in.

# ─── Required ────────────────────────────────────────────────────────────

# Anthropic API Key (Server-side LLM)
ANTHROPIC_API_KEY=""

# Turso (libsql). Local: file:./data/dev.db. Production: libsql://<db>.turso.io
DATABASE_URL="file:./data/dev.db"
DATABASE_AUTH_TOKEN=""

# better-auth Session-Secret. Generate via:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Resend (for Magic-Link Emails)
RESEND_API_KEY=""
RESEND_FROM="Tagesplan-Briefing <info@appsales-consulting.de>"

# ─── Web Research (Pick ONE) ─────────────────────────────────────────────
# Tavily (recommended for AI agents, generous free tier)
TAVILY_API_KEY=""
# Alternative: Exa
EXA_API_KEY=""

# ─── Calendar: Service-Account-Sharing ───────────────────────────────────
# Google Workspace Account, der freigegebene Kalender empfaengt
SERVICE_CALENDAR_EMAIL="briefing@appsales-consulting.com"
# OAuth-Credentials fuer dieses Konto (eingeloggt via Workspace-Login)
GOOGLE_SERVICE_CLIENT_ID=""
GOOGLE_SERVICE_CLIENT_SECRET=""
GOOGLE_SERVICE_REFRESH_TOKEN=""

# ─── Rate Limits ─────────────────────────────────────────────────────────
BRIEFING_LIMIT_PER_EMAIL="3"
BRIEFING_LIMIT_GLOBAL_DAILY="50"
